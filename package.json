{
  "name": "devpulse-ai",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:github-pages": "ng build --configuration production --base-href /devpulse-ai/",
    "build:stats": "ng build --stats-json",
    "analyze": "npx source-map-explorer \"dist/devpulse-ai/**/*.js\"",
    "serve:dist": "npx http-server dist/devpulse-ai/browser -p 8080 -c-1",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=chromium",
    "test:coverage": "ng test --watch=false --browsers=chromium --coverage"
  },
  "private": true,
  "packageManager": "npm@11.14.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@ngrx/signals": "^21.1.0",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/browser-preview": "^4.1.6",
    "@vitest/browser-webdriverio": "^4.1.6",
    "axios": "^1.16.0",
    "dexie": "^4.4.2",
    "jasmine": "^6.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/coverage-v8": "^4.1.6",
    "http-server": "^14.1.1",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
